# Normalización de fin de línea. Crítico en Windows: si git hace checkout de
# los .sh con CRLF, el entrypoint del contenedor muere con "bad interpreter"
# y bash no puede ejecutar doctor.sh. Todo lo que se ejecuta dentro de un
# contenedor Linux o por make debe ser LF siempre.
* text=auto

*.sh       text eol=lf
Makefile   text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.conf     text eol=lf
*.ini      text eol=lf
*.env      text eol=lf
.env.example text eol=lf
Dockerfile text eol=lf

# Binarios comunes: nunca tocar
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.crt binary
*.pem binary

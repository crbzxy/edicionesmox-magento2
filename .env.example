# === Proyecto ===
PROJECT_NAME=edicionesmox-magento2

# Versión de Magento Open Source que instala `make install-oss` si no se pasa
# VERSION=x.y.z explícito.
MAGENTO_VERSION=2.4.8

# === PHP ===
# Magento Open Source 2.4.8 soporta 8.3 y 8.4. Usamos 8.3 por estabilidad
# con extensiones de terceros (muchas aun no certifican 8.4/8.5).
PHP_VERSION=8.3
PHP_MEMORY_LIMIT=2G

# === Nginx ===
NGINX_VERSION=1.28-alpine
# 127.0.0.1 = solo esta máquina (igual que DB/Redis/OpenSearch). Cambia a
# 0.0.0.0 si necesitas probar el storefront desde otro dispositivo de tu red
# (móvil, otra laptop).
NGINX_BIND_ADDRESS=127.0.0.1
# NGINX_PORT (80->8080) solo redirige a https, nunca sirve contenido.
# NGINX_HTTPS_PORT (443->8443) es el puerto real del storefront/admin.
# Certificado self-signed generado por el propio contenedor de nginx (ver
# docker/nginx/docker-entrypoint.sh): el navegador mostrará advertencia de
# certificado no confiable, es esperado en local.
# Si cambias NGINX_HTTPS_PORT, actualiza también el redirect hardcodeado en
# docker/nginx/default.conf (no pasa por envsubst).
NGINX_PORT=8080
NGINX_HTTPS_PORT=8443

# === Base de datos ===
MARIADB_VERSION=11.4
MARIADB_BUFFER_POOL_SIZE=1G
DB_BIND_ADDRESS=127.0.0.1
DB_PORT=3306
DB_ROOT_PASSWORD=magento_root
DB_NAME=magento
DB_USER=magento
DB_PASSWORD=magento

# === OpenSearch ===
OPENSEARCH_VERSION=2.19.0
OPENSEARCH_BIND_ADDRESS=127.0.0.1
OPENSEARCH_PORT=9200
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# === Redis ===
REDIS_VERSION=7.2-alpine
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb

# === Mailpit ===
MAILPIT_VERSION=v1.30
MAILPIT_BIND_ADDRESS=127.0.0.1
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

# === Usuario admin de Magento ===
# Usado por `make setup-install` y `make admin-create`.
# Password: mínimo 7 caracteres con letras y números. Evita el carácter `$`
# (make lo interpreta como variable).
ADMIN_FIRSTNAME=Admin
ADMIN_LASTNAME=Local
ADMIN_EMAIL=admin@example.com
ADMIN_USER=admin
ADMIN_PASSWORD=ChangeMe123!

# === Certificado corporativo (Netskope u otro proxy con SSL inspection) ===
# No es una variable: el mecanismo es la PRESENCIA del archivo. Si estás detrás
# de un proxy corporativo, exporta el certificado raíz (p.ej. el de Netskope) a:
#   docker/php/certs/corporate-ca.crt
# y reconstruye la imagen (make build). El Dockerfile copia cualquier .crt de
# esa carpeta al almacén de confianza del contenedor. Si la carpeta está
# vacía, no pasa nada. (La variable CORPORATE_CA_CERT que existía antes nunca
# fue leída por nada — se eliminó del contrato.)

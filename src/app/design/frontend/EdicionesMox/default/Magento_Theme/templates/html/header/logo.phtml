<?php
/**
 * @var \Magento\Theme\Block\Html\Header\Logo $block
 * @var \Magento\Framework\Escaper $escaper
 * @var \EdicionesMox\Storefront\ViewModel\Navigation|null $navigationViewModel
 */
$storeName = 'Ediciones Mox';
$logoSrc = $block->getViewFileUrl('images/edmox/logo-edmox.webp');
$navigationViewModel = $block->getData('navigation_view_model');
$ariaLabelToggleNav = $navigationViewModel
    ? $navigationViewModel->getAriaLabelToggleNav()
    : (string) __('Toggle main navigation');
?>
<span data-action="toggle-nav" class="action nav-toggle">
    <span><?= $escaper->escapeHtml(__('Toggle Nav')) ?></span>
</span>
<a
    class="logo edmox-logo"
    href="<?= $escaper->escapeUrl($block->getUrl('')) ?>"
    title="<?= $escaper->escapeHtmlAttr($storeName) ?>"
    aria-label="<?= $escaper->escapeHtmlAttr(__('Ediciones Mox — inicio')) ?>">
    <img src="<?= $escaper->escapeUrl($logoSrc) ?>"
         title="<?= $escaper->escapeHtmlAttr($storeName) ?>"
         alt="<?= $escaper->escapeHtmlAttr($storeName) ?>"
         width="140"
         height="40"
    />
</a>
<script type="text/x-magento-init">
{
    ".page-header": {
        "edmoxNavigation": {
            "ariaLabel": "<?= $escaper->escapeJs($ariaLabelToggleNav) ?>"
        }
    }
}
</script>
